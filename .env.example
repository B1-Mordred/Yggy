# Automation API
AUTOMATION_API_HOST=0.0.0.0
AUTOMATION_API_PORT=8088
AUTOMATION_TOOL_API_KEY=replace-with-long-random-tool-key
AUTOMATION_ADMIN_API_KEY=replace-with-long-random-admin-key
AUTOMATION_WORKER_API_KEY=replace-with-long-random-worker-key

# Bragi natural human-facing agent
BRAGI_MODEL_ID=bragi
BRAGI_API_KEY=replace-with-long-random-bragi-key
BRAGI_DEFAULT_USER_ID=local_user
BRAGI_PORT=8650
BRAGI_LAN_PUBLISHED_HOST=replace-with-host-lan-ip-if-needed
BRAGI_LAN_PUBLISHED_PORT=8650
BRAGI_HTTP_TIMEOUT=30
BRAGI_GENERAL_CHAT_ENABLED=true
BRAGI_CHAT_MODEL=llama3.1:8b
BRAGI_CHAT_TEMPERATURE=0.55
BRAGI_CHAT_TIMEOUT=30
BRAGI_CHAT_NUM_CTX=4096
BRAGI_CHAT_MAX_TOKENS=512
BRAGI_CONFIG_ROOT=/app/configs
BRAGI_MEMORY_FILE=/app/configs/bragi/memory.yaml
BRAGI_MEMORY_DATABASE_URL=mysql+pymysql://automation:replace-with-random-password@automation-mysql:3306/automation
YGGDRASIL_BASE_URL=http://host.docker.internal:8642
BRAGI_YGGDRASIL_API_KEY=replace-with-yggdrasil-action-api-key-if-configured

# Optional LAN dashboard/API exposure, used only with docker-compose.lan.yml
AUTOMATION_API_LAN_PUBLISHED_HOST=replace-with-host-lan-ip
AUTOMATION_API_LAN_PUBLISHED_PORT=8088
AUTOMATION_DASHBOARD_ALLOWED_CIDR=replace-with-trusted-client-cidr

# Optional HTTPS reverse proxy for the operations dashboard/API
YGGY_HTTPS_HOST=yggy.b1.germering
YGGY_HTTPS_PUBLISHED_HOST=replace-with-host-lan-ip
YGGY_HTTPS_PUBLISHED_PORT=8443
YGGY_HTTPS_ALLOWED_CIDR=replace-with-trusted-client-cidr

# Database
MYSQL_DATABASE=automation
MYSQL_USER=automation
MYSQL_PASSWORD=replace-with-random-password
MYSQL_ROOT_PASSWORD=replace-with-random-root-password
DATABASE_URL=mysql+pymysql://automation:replace-with-random-password@automation-mysql:3306/automation

# Discord
DISCORD_DRY_RUN=true
DISCORD_WEBHOOK_BRIEFINGS=replace-with-discord-webhook-url
DISCORD_WEBHOOK_ALERTS=replace-with-discord-webhook-url
DISCORD_WEBHOOK_APPROVALS=replace-with-discord-webhook-url
DISCORD_BOT_TOKEN=replace-with-discord-bot-token
DISCORD_HOME_CHANNEL=replace-with-discord-channel-id
DISCORD_ALLOWED_USER_IDS=replace-with-comma-separated-discord-user-ids-or-empty
DISCORD_CHANNEL_BRIEFINGS=replace-with-discord-channel-id
DISCORD_CHANNEL_ALERTS=replace-with-discord-channel-id
DISCORD_CHANNEL_APPROVALS=replace-with-discord-channel-id

# n8n
N8N_ENCRYPTION_KEY=replace-with-random-32-byte-string
N8N_HOST=127.0.0.1
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://127.0.0.1:5678/
N8N_WEBHOOK_BASE_URL=http://n8n:5678
N8N_WEBHOOK_SHARED_SECRET=replace-with-long-random-n8n-webhook-secret

# Optional LLM summarizer
OLLAMA_BASE_URL=http://host.docker.internal:11434
LLM_SUMMARIZER_ENABLED=false
LLM_SUMMARIZER_MODEL=granite4.1:8b
LLM_SUMMARIZER_TIMEOUT_SECONDS=120
LLM_SUMMARIZER_MAX_ITEMS=5
LLM_SUMMARIZER_MAX_CHARS_PER_ITEM=350
LLM_SUMMARIZER_MAX_OUTPUT_CHARS=1800

# Runtime
TZ=Europe/Berlin
LOG_LEVEL=info
AUTOMATION_RUN_DEDUPE_SECONDS=300
AUTOMATION_RUN_LEASE_SECONDS=1800
AUTOMATION_SOURCE_REGISTRY_FILE=/app/configs/sources/approved_sources.yaml
YGGY_METRICS_CONFIG=/app/configs/metrics/services.yaml
YGGY_BACKUP_VERIFY_ROOT=/app/backups
YGGY_WORKER_UID=1000
YGGY_WORKER_GID=1000
AUTOMATION_RUN_RETENTION_DAYS=30
AUTOMATION_AUDIT_RETENTION_DAYS=90
AUTOMATION_TEMP_TASK_RETENTION_HOURS=24
AUTOMATION_RETENTION_INTERVAL_SECONDS=86400
AUTOMATION_STALE_RUN_RECOVERY_INTERVAL_SECONDS=300

# Local read-only operations dashboard
AUTOMATION_OPS_DASHBOARD_ENABLED=true
AUTOMATION_OPS_DASHBOARD_USER=admin
AUTOMATION_OPS_DASHBOARD_PASSWORD=replace-with-long-random-dashboard-password
