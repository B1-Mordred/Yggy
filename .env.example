# Automation API
AUTOMATION_API_HOST=0.0.0.0
AUTOMATION_API_PORT=8088
AUTOMATION_TOOL_API_KEY=replace-with-long-random-tool-key
AUTOMATION_ADMIN_API_KEY=replace-with-long-random-admin-key
AUTOMATION_WORKER_API_KEY=replace-with-long-random-worker-key

# Database
MYSQL_DATABASE=automation
MYSQL_USER=automation
MYSQL_PASSWORD=replace-with-random-password
MYSQL_ROOT_PASSWORD=replace-with-random-root-password
DATABASE_URL=mysql+pymysql://automation:replace-with-random-password@automation-mysql:3306/automation

# Discord
DISCORD_DRY_RUN=true
DISCORD_WEBHOOK_BRIEFINGS=replace-with-discord-webhook-url
DISCORD_WEBHOOK_ALERTS=replace-with-discord-webhook-url
DISCORD_WEBHOOK_APPROVALS=replace-with-discord-webhook-url

# n8n
N8N_ENCRYPTION_KEY=replace-with-random-32-byte-string
N8N_HOST=127.0.0.1
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://127.0.0.1:5678/

# Optional LLM summarizer
OLLAMA_BASE_URL=http://host.docker.internal:11434
LLM_SUMMARIZER_ENABLED=false
LLM_SUMMARIZER_MODEL=llama3.1

# Runtime
TZ=Europe/Berlin
LOG_LEVEL=info
